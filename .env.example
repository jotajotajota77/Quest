# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://jxixjfokmmeigyxiadzh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role: usado só em rotas server-side de manutenção. NUNCA exponha ao cliente.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Spotify (usuário Premium + developer app) ──────────────
# Web Playback SDK exige Premium. Redirect URI deve bater com o configurado no dashboard.
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# Origem da app (para redirects de auth). Em produção: https://seu-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Análise de treino por IA (Claude API) — OPCIONAL ───────
# Fora do loop crítico: sem esta key, a análise degrada com "sem análise nesta
# sessão" e o app funciona igual. Plugue na Vercel quando quiser ligar.
ANTHROPIC_API_KEY=sk-ant-...
