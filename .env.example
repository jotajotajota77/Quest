# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://jxixjfokmmeigyxiadzh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role: usado só em rotas server-side de manutenção. NUNCA exponha ao cliente.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Spotify (usuário Premium + developer app) ──────────────
# Web Playback SDK exige Premium. SECRET e tokens vivem SÓ no servidor: nunca no
# bundle client, nunca commitados. O client_id também é lido só no servidor
# (route handler de login + troca de token), então NÃO leva NEXT_PUBLIC.
# O Redirect URI deve bater EXATAMENTE com o cadastrado no dashboard:
#   dev:  http://localhost:3000/api/spotify/callback
#   prod: https://<seu-app>.vercel.app/api/spotify/callback
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# Origem da app (para redirects de auth). Em produção: https://seu-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Análise de treino por IA (Claude API) — OPCIONAL ───────
# Fora do loop crítico: sem esta key, a análise degrada com "sem análise nesta
# sessão" e o app funciona igual. Plugue na Vercel quando quiser ligar.
ANTHROPIC_API_KEY=sk-ant-...
